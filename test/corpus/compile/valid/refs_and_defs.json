{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/address",
  "$defs": {
    "address": {
      "type": "object",
      "properties": {
        "street": { "type": "string" },
        "city": { "$ref": "#/$defs/city" }
      }
    },
    "city": {
      "type": "string",
      "minLength": 1
    }
  }
}
