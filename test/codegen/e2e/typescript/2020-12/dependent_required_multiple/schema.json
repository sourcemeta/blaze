{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "credit_card": { "type": "string" },
    "billing_address": { "type": "string" },
    "billing_zip": { "type": "string" },
    "phone": { "type": "string" },
    "country_code": { "type": "string" }
  },
  "dependentRequired": {
    "credit_card": [ "billing_address", "billing_zip" ],
    "phone": [ "country_code" ]
  }
}
